# ===========================================================================
# Inter Token Server — Environment Variables
# Copy this file to .env and fill in your values.
# ===========================================================================

# Redis connection URL
# Default (dev): redis://localhost:6379
# Production: Use Upstash Redis URL
REDIS_URL=redis://localhost:6379

# PostgreSQL connection URL
# Default (dev): postgresql://localhost:5432/inter_dev
# Production: Use Neon PostgreSQL URL
DATABASE_URL=postgresql://localhost:5432/inter_dev

# LiveKit credentials (server-side only — NEVER expose to client)
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# JWT secret for user authentication tokens (NOT LiveKit tokens)
# REQUIRED — server will refuse to start without this set to >= 32 bytes.
# No default. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
JWT_SECRET=

# LiveKit server URL (WebSocket) — sent to client for connection
LIVEKIT_SERVER_URL=ws://localhost:7880

# Token server port
PORT=3000
