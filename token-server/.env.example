# ===========================================================================
# Inter Token Server — Environment Variables
# Copy this file to .env and fill in your values.
# ===========================================================================

# Redis connection URL
# Default (dev): redis://localhost:6379
# Production: Use Upstash Redis URL
REDIS_URL=redis://localhost:6379

# PostgreSQL connection URL
# Default (dev): postgresql://localhost:5432/inter_dev
# Production: Use Neon PostgreSQL URL
DATABASE_URL=postgresql://localhost:5432/inter_dev

# LiveKit credentials (server-side only — NEVER expose to client)
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# JWT secret for user authentication tokens (NOT LiveKit tokens)
# REQUIRED — server will refuse to start without this set to >= 32 bytes.
# No default. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
JWT_SECRET=

# LiveKit server URL (WebSocket) — sent to client for connection
LIVEKIT_SERVER_URL=ws://localhost:7880

# LiveKit HTTP URL — used by the server-side Egress client and RoomServiceClient.
# Must point at the LiveKit server's HTTP port (same host as LIVEKIT_SERVER_URL).
LIVEKIT_HTTP_URL=http://localhost:7880

# Token server port
PORT=3000

# ---------------------------------------------------------------------------
# Phase B — Refresh Token System
# Required when implementing Phase B (two-token auth).
# ---------------------------------------------------------------------------

# Secret for signing/verifying refresh token meta-operations.
# REQUIRED for Phase B. Must be >= 32 bytes. Different from JWT_SECRET.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
REFRESH_TOKEN_SECRET=

# Access token TTL (Phase B — replaces 7-day JWT with short-lived access tokens)
ACCESS_TOKEN_TTL=15m

# Refresh token TTL in days (rolling window)
REFRESH_TOKEN_TTL_DAYS=30

# ---------------------------------------------------------------------------
# Phase C — Lemon Squeezy Billing (Merchant of Record)
# Required when implementing Phase C (subscription lifecycle webhooks).
# ---------------------------------------------------------------------------

# Lemon Squeezy API key — from LS Dashboard → Settings → API
# Used server-side only for creating checkouts, managing subscriptions.
# Test mode: separate key from LS test environment
# NEVER expose to client.
LEMONSQUEEZY_API_KEY=

# Lemon Squeezy webhook signing secret — from LS Dashboard → Settings → Webhooks
# Used to verify HMAC-SHA256 signatures in the X-Signature header.
# REQUIRED for billing to function. 6-40 characters.
LEMONSQUEEZY_WEBHOOK_SECRET=

# Lemon Squeezy Store ID — from LS Dashboard → Settings → General
# Required for creating checkout URLs.
LEMONSQUEEZY_STORE_ID=

# App return URL — shown in Lemon Squeezy Checkout redirect after payment
# For dev: http://localhost:3000 | Production: https://your-domain.com
APP_RETURN_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Phase D — Email / Mailer
# Required when implementing Phase D (password reset, email verification).
# Use any SMTP provider: Resend, SendGrid, Postmark, or direct SMTP.
# ---------------------------------------------------------------------------

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# The "from" address shown in password reset and verification emails
SMTP_FROM=noreply@your-domain.com

# ---------------------------------------------------------------------------
# Phase D — Security Alerting (optional but recommended)
# Receives a POST when a stolen refresh token is detected (SESSION_COMPROMISED).
# Set to a Slack Incoming Webhook URL: https://api.slack.com/messaging/webhooks
# Leave blank in dev — alerts are console.error() only when unset.
# ---------------------------------------------------------------------------

SECURITY_WEBHOOK_URL=

# ---------------------------------------------------------------------------
# Cloud Recording — AWS S3 + LiveKit Egress
# Required only if cloud recording (Pro/Hiring tier) will be used.
# ---------------------------------------------------------------------------

# S3 bucket where LiveKit Egress will write recording files.
# Create this bucket in AWS Console before enabling cloud recording.
# The Egress Docker container also needs these credentials (pass as env vars
# when running: docker run -e AWS_ACCESS_KEY_ID=... livekit/egress)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_RECORDINGS_BUCKET=inter-recordings

# Cloud recording quotas (minutes per user per month)
RECORDING_QUOTA_PRO=600
RECORDING_QUOTA_HIRING=1200

# ---------------------------------------------------------------------------
# LiveKit Egress Service
# The Egress API is a SEPARATE Docker container — not part of the LiveKit server.
# Run it locally with:
#
#   docker run --rm \
#     -e LIVEKIT_URL=ws://localhost:7880 \
#     -e LIVEKIT_API_KEY=devkey \
#     -e LIVEKIT_API_SECRET=secret \
#     -e AWS_ACCESS_KEY_ID=your_key \
#     -e AWS_SECRET_ACCESS_KEY=your_secret \
#     -e AWS_DEFAULT_REGION=us-east-1 \
#     livekit/egress
#
# Without this container running, POST /room/record/start will fail.
# Cloud recording is a Pro/Hiring-only feature — free tier is local only.
# ---------------------------------------------------------------------------
